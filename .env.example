# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env, fill in all values, then: chmod 600 .env
# NEVER commit .env – it is gitignored.
#
# Passwords/secrets that go into Docker secret files (never in this file):
#   secrets/postgres_password.txt     → postgres + DATABASE_URL password
#   secrets/pgadmin_password.txt      → pgAdmin UI password
#   secrets/auth_session_secret.txt   → cookie signing key  (openssl rand -hex 64)
#   secrets/auth_admin_password.txt   → CMS local admin password
#   secrets/github_client_secret.txt  → GitHub OAuth app secret
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker / Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=faelab
POSTGRES_DB=faelab
PGADMIN_DEFAULT_EMAIL=admin@example.com
# DATABASE_URL includes the password inline (must match secrets/postgres_password.txt)
DATABASE_URL=postgresql://faelab:CHANGE_ME@postgres:5432/faelab

# ── Frontend build ────────────────────────────────────────────────────────────
# Public domain – baked into the React bundle at build time
VITE_API_BASE_URL=https://yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ── Session ───────────────────────────────────────────────────────────────────
# AUTH_SESSION_SECRET → secrets/auth_session_secret.txt  (openssl rand -hex 64)
AUTH_SESSION_TTL_DAYS=7

# ── Auth method: github | local ───────────────────────────────────────────────
AUTH_METHOD=github

# GitHub OAuth (AUTH_METHOD=github)
GITHUB_CLIENT_ID=CHANGE_ME
# GITHUB_CLIENT_SECRET → secrets/github_client_secret.txt
GITHUB_CALLBACK_URL=https://yourdomain.com/auth/github/callback
AUTH_ALLOWED_GITHUB_LOGIN=your-github-username
AUTH_ALLOWED_GITHUB_ID=your-github-numeric-id

# Local admin (AUTH_METHOD=local)
AUTH_ADMIN_USERNAME=admin
# AUTH_ADMIN_PASSWORD → secrets/auth_admin_password.txt

# ── Auth redirects ────────────────────────────────────────────────────────────
AUTH_SUCCESS_REDIRECT=https://yourdomain.com/projects
AUTH_FAILURE_REDIRECT=https://yourdomain.com/projects?auth=failed