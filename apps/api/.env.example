# ─────────────────────────────────────────────────────────────────────────────
# Local development env for apps/api.
# Copy to apps/api/.env and adjust values.
# This file is for local dev only – in production all vars are injected by
# Docker Compose (no .env file inside the container).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=CHANGE_ME
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection string (expands the variables above via dotenv-expand)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Auth method: github | local ───────────────────────────────────────────────
AUTH_METHOD=local

# Local admin (AUTH_METHOD=local)
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=LOCAL_DEV_PWD_CHANGE_ME

# GitHub OAuth (AUTH_METHOD=github)
# Create a GitHub OAuth App: https://github.com/settings/developers
# Callback URL: http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
AUTH_ALLOWED_GITHUB_LOGIN=your-github-username
AUTH_ALLOWED_GITHUB_ID=your-github-numeric-id
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── Session ───────────────────────────────────────────────────────────────────
AUTH_SESSION_SECRET=DEV_SECRET_CHANGE_ME
AUTH_SESSION_TTL_DAYS=7

# ── Redirects ─────────────────────────────────────────────────────────────────
AUTH_SUCCESS_REDIRECT=http://localhost:5173/projects
AUTH_FAILURE_REDIRECT=http://localhost:5173/projects?auth=failed

# ── Dev-only bypass (skips OAuth entirely, never use in production) ───────────
AUTH_DEV_BYPASS=false
AUTH_DEV_BYPASS_LOGIN=dev-admin

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_BASE_DIR=./uploads
UPLOAD_MAX_FILE_SIZE=104857600
